// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id            Int                   @id @default(autoincrement())
  slug          String                @unique
  name          String
  nameEn        String                @default("")
  description   String
  descriptionEn String                @default("")
  imageUrl      String
  productCount  Int                   @default(0)
  products      Product[]
  translations  CategoryTranslation[]
}

model Product {
  id            Int                  @id @default(autoincrement())
  slug          String               @unique
  categoryId    Int
  category      Category             @relation(fields: [categoryId], references: [id])
  name          String
  nameEn        String               @default("")
  description   String
  descriptionEn String               @default("")
  advantages    String // JSON string or comma-separated for sqlite
  advantagesEn  String               @default("") // English translation or blank fallback
  composition   String               @default("") // JSON string or line-based pairs
  compositionEn String               @default("") // English translation or blank fallback
  application   String               @default("") // JSON string or blank-line separated blocks
  applicationEn String               @default("") // English translation or blank fallback
  imageUrl      String
  imageUrlEn    String               @default("")
  translations  ProductTranslation[]
}

model Article {
  id                  Int                  @id @default(autoincrement())
  slug                String?              @unique
  title               String
  titleEn             String               @default("")
  excerpt             String               @default("")
  excerptEn           String               @default("")
  content             String
  contentEn           String               @default("")
  imageUrl            String
  publishedAt         DateTime             @default(now())
  viewCount           Int                  @default(0)
  coverMediaId        String?
  imageLayoutJson     Json?
  imageLayoutRevision Int                  @default(0)
  updatedAt           DateTime             @updatedAt
  translations        ArticleTranslation[]
  drafts              ArticleDraft[]
  media               ArticleMedia[]
}

model CalendarEntry {
  id            Int                        @id @default(autoincrement())
  slug          String                     @unique
  title         String
  titleEn       String                     @default("")
  description   String
  descriptionEn String                     @default("")
  imageUrl1     String
  imageUrl2     String
  imageUrl3     String
  imageUrl4     String
  pdfUrl        String                     @default("")
  translations  CalendarEntryTranslation[]
}

model CategoryTranslation {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      String
  name        String   @default("")
  description String   @default("")

  @@unique([categoryId, locale])
  @@index([locale])
}

model ProductTranslation {
  id          Int     @id @default(autoincrement())
  productId   Int
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      String
  name        String  @default("")
  description String  @default("")
  advantages  String  @default("")
  composition String  @default("")
  application String  @default("")

  @@unique([productId, locale])
  @@index([locale])
}

model ArticleTranslation {
  id                   Int      @id @default(autoincrement())
  articleId            Int
  article              Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale               String
  title                String   @default("")
  excerpt              String   @default("")
  content              String   @default("")
  contentJson          Json?
  contentSchemaVersion Int?
  revision             Int      @default(0)
  updatedAt            DateTime @updatedAt

  @@unique([articleId, locale])
  @@index([locale])
}

enum ArticleMediaRole {
  COVER
  CONTENT
}

enum ArticleMediaStatus {
  DRAFT
  ATTACHED
  PENDING_DELETE
}

model ArticleDraft {
  id                   String         @id
  articleId            Int?
  article              Article?       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale               String
  title                String         @default("")
  excerpt              String         @default("")
  contentJson          Json
  contentSchemaVersion Int            @default(1)
  publishedAt          DateTime       @default(now())
  coverMediaId         String?
  imageLayoutRevision  Int            @default(0)
  version              Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  media                ArticleMedia[]

  @@unique([articleId, locale])
  @@index([locale])
  @@index([updatedAt])
}

model ArticleMedia {
  id           String             @id
  uploadId     String             @unique
  role         ArticleMediaRole
  status       ArticleMediaStatus @default(DRAFT)
  articleId    Int?
  article      Article?           @relation(fields: [articleId], references: [id], onDelete: SetNull)
  draftId      String?
  draft        ArticleDraft?      @relation(fields: [draftId], references: [id], onDelete: SetNull)
  storagePath  String             @unique
  previewPath  String             @unique
  publicUrl    String             @unique
  previewUrl   String             @unique
  mimeType     String
  originalName String
  byteSize     Int
  width        Int
  height       Int
  pages        Int                @default(1)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([articleId])
  @@index([draftId])
  @@index([status])
}

model CalendarEntryTranslation {
  id              Int           @id @default(autoincrement())
  calendarEntryId Int
  calendarEntry   CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)
  locale          String
  title           String        @default("")
  description     String        @default("")
  imageUrl3       String        @default("")
  pdfUrl          String        @default("")

  @@unique([calendarEntryId, locale])
  @@index([locale])
}
