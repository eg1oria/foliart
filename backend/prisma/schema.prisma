// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String
  nameEn       String    @default("")
  description  String
  descriptionEn String   @default("")
  imageUrl     String
  productCount Int       @default(0)
  products     Product[]
  translations  CategoryTranslation[]
}

model Product {
  id            Int      @id @default(autoincrement())
  categoryId    Int
  category      Category @relation(fields: [categoryId], references: [id])
  name          String
  nameEn        String   @default("")
  description   String
  descriptionEn String   @default("")
  advantages    String   // JSON string or comma-separated for sqlite
  advantagesEn  String   @default("") // English translation or blank fallback
  composition   String   @default("") // JSON string or line-based pairs
  compositionEn String   @default("") // English translation or blank fallback
  application   String   @default("") // JSON string or blank-line separated blocks
  applicationEn String   @default("") // English translation or blank fallback
  imageUrl      String
  imageUrlEn    String   @default("")
  translations  ProductTranslation[]
}

model Article {
  id         Int      @id @default(autoincrement())
  title      String
  titleEn    String   @default("")
  excerpt    String   @default("")
  excerptEn  String   @default("")
  content    String
  contentEn  String   @default("")
  imageUrl   String
  publishedAt DateTime @default(now())
  viewCount  Int      @default(0)
  translations ArticleTranslation[]
}

model CalendarEntry {
  id            Int    @id @default(autoincrement())
  title         String
  titleEn       String @default("")
  description   String
  descriptionEn String @default("")
  imageUrl1     String
  imageUrl2     String
  imageUrl3     String
  imageUrl4     String
  translations  CalendarEntryTranslation[]
}

model CategoryTranslation {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      String
  name        String   @default("")
  description String   @default("")

  @@unique([categoryId, locale])
  @@index([locale])
}

model ProductTranslation {
  id          Int     @id @default(autoincrement())
  productId   Int
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      String
  name        String  @default("")
  description String  @default("")
  advantages  String  @default("")
  composition String  @default("")
  application String  @default("")

  @@unique([productId, locale])
  @@index([locale])
}

model ArticleTranslation {
  id        Int     @id @default(autoincrement())
  articleId Int
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale    String
  title     String  @default("")
  excerpt   String  @default("")
  content   String  @default("")

  @@unique([articleId, locale])
  @@index([locale])
}

model CalendarEntryTranslation {
  id              Int           @id @default(autoincrement())
  calendarEntryId Int
  calendarEntry   CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)
  locale          String
  title           String        @default("")
  description     String        @default("")

  @@unique([calendarEntryId, locale])
  @@index([locale])
}
