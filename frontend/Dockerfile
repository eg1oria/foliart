FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci || npm install

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_URL=/api
ARG BACKEND_URL=http://localhost:3001
ARG SITE_URL=http://localhost:3000
ARG NEXT_PUBLIC_SITE_URL=$SITE_URL
ARG NEXT_PUBLIC_CDN_URL=
ARG NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN=false
ARG ASSET_PREFIX=
ARG ENABLE_ASSET_PREFIX=false
ARG ENABLE_IMAGE_CDN=false
ARG ADMIN_USERNAME=admin
ARG ADMIN_PASSWORD=Foliart2026!
ARG ADMIN_SESSION_SECRET=foliart-admin-session-secret-2026
ARG ADMIN_API_SECRET=foliart-admin-api-secret-2026
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV BACKEND_URL=$BACKEND_URL
ENV SITE_URL=$SITE_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_CDN_URL=$NEXT_PUBLIC_CDN_URL
ENV NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN=$NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN
ENV ASSET_PREFIX=$ASSET_PREFIX
ENV ENABLE_ASSET_PREFIX=$ENABLE_ASSET_PREFIX
ENV ENABLE_IMAGE_CDN=$ENABLE_IMAGE_CDN
ENV ADMIN_USERNAME=$ADMIN_USERNAME
ENV ADMIN_PASSWORD=$ADMIN_PASSWORD
ENV ADMIN_SESSION_SECRET=$ADMIN_SESSION_SECRET
ENV ADMIN_API_SECRET=$ADMIN_API_SECRET
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:20-alpine AS production
WORKDIR /app
ARG SITE_URL=http://localhost:3000
ARG NEXT_PUBLIC_SITE_URL=$SITE_URL
ARG NEXT_PUBLIC_CDN_URL=
ARG NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN=false
ARG ASSET_PREFIX=
ARG ENABLE_ASSET_PREFIX=false
ARG ENABLE_IMAGE_CDN=false
ARG ADMIN_USERNAME=admin
ARG ADMIN_PASSWORD=Foliart2026!
ARG ADMIN_SESSION_SECRET=foliart-admin-session-secret-2026
ARG ADMIN_API_SECRET=foliart-admin-api-secret-2026
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV SITE_URL=$SITE_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_CDN_URL=$NEXT_PUBLIC_CDN_URL
ENV NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN=$NEXT_PUBLIC_ENABLE_PUBLIC_ASSET_CDN
ENV ASSET_PREFIX=$ASSET_PREFIX
ENV ENABLE_ASSET_PREFIX=$ENABLE_ASSET_PREFIX
ENV ENABLE_IMAGE_CDN=$ENABLE_IMAGE_CDN
ENV ADMIN_USERNAME=$ADMIN_USERNAME
ENV ADMIN_PASSWORD=$ADMIN_PASSWORD
ENV ADMIN_SESSION_SECRET=$ADMIN_SESSION_SECRET
ENV ADMIN_API_SECRET=$ADMIN_API_SECRET

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000

CMD ["node", "server.js"]
